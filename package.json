{
  "name": "@tklsn/deck",
  "version": "1.5.1",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build:web": "vite build",
    "build:main": "tsc -p tsconfig.electron.json",
    "build": "pnpm run build:web && pnpm run build:main && electron-builder",
    "electron:dev": "node scripts/electron-dev.mjs",
    "preview": "vite preview",
    "shadcn": "pnpm dlx shadcn-vue@latest",
    "app:dir": "pnpm run build:web && pnpm run build:main && electron-builder --dir",
    "app:dist": "pnpm run build",
    "changelog": "changelogen",
    "release": "changelogen --release && git push && git push origin \"v$(node -p 'require(\"./package.json\").version')\" --force"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.0",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "^4.3.0",
    "dompurify": "^3.3.3",
    "electron-updater": "^6.6.2",
    "lucide-vue-next": "^0.575.0",
    "marked": "^17.0.3",
    "ofetch": "^1.5.1",
    "openai": "^6.22.0",
    "reka-ui": "^2.8.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.0",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.25",
    "vue-router": "^5.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@iconify-json/radix-icons": "^1.2.6",
    "@iconify/vue": "^5.0.0",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vitejs/plugin-vue-jsx": "^5.1.4",
    "@vue/tsconfig": "^0.8.1",
    "changelogen": "^0.5.7",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.0-beta.13",
    "vite-tsconfig-paths": "^6.1.1",
    "vue-tsc": "^3.1.5"
  },
  "pnpm": {
    "overrides": {
      "vite": "^8.0.0-beta.13"
    },
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild",
      "vue-demi"
    ]
  },
  "build": {
    "productName": "deck",
    "appId": "br.com.tksn.deck",
    "icon": "build/icon.png",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json",
      "!dist/builder-effective-config.yaml"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "tklsn",
        "repo": "deck"
      }
    ],
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    }
  }
}
