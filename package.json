{
  "name": "@tklsn/deck",
  "version": "1.6.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build:web": "vite build",
    "build:main": "tsc -p tsconfig.electron.json",
    "build": "pnpm run build:web && pnpm run build:main && electron-builder",
    "electron:dev": "node scripts/electron-dev.mjs",
    "preview": "vite preview",
    "shadcn": "pnpm dlx shadcn-vue@latest",
    "app:dir": "pnpm run build:web && pnpm run build:main && electron-builder --dir",
    "app:dist": "pnpm run build",
    "changelog": "changelogen",
    "release": "changelogen --release && git push && git push origin \"v$(node -p 'require(\"./package.json\").version')\" --force"
  },
  "dependencies": {
    "@lucide/vue": "^1.16.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "^4.4.2",
    "dompurify": "^3.4.5",
    "electron-updater": "^6.8.3",
    "marked": "^18.0.4",
    "ofetch": "^1.5.1",
    "openai": "^6.38.0",
    "reka-ui": "^2.9.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@iconify-json/radix-icons": "^1.2.6",
    "@iconify/vue": "^5.0.1",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/tsconfig": "^0.9.1",
    "changelogen": "^0.6.2",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.13",
    "vue-tsc": "^3.3.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild",
      "vue-demi"
    ]
  },
  "build": {
    "productName": "deck",
    "appId": "br.com.tksn.deck",
    "icon": "build/icon.png",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json",
      "!dist/builder-effective-config.yaml"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "tklsn",
        "repo": "deck"
      }
    ],
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    }
  }
}
